                depends on BLUCONTROL_RIGHT_STICK_N64
                help
                    GPIO Number for the Right Stick Y Axis Interrupt.

            config BLUCONTROL_RIGHT_STICK_Y2
                int "Right Stick Y Axis Counter"
                default 39
                range 0 50
                depends on BLUCONTROL_RIGHT_STICK_N64
                help
                    GPIO Number for the Right Stick Y Axis Counter.

                    #Buttons

            config BLUCONTROL_RIGHT_STICK_X_MAX
                int "Right Stick X Axis Positive"
                default 36
                range 0 50
                depends on BLUCONTROL_RIGHT_STICK_BUTTONS
                help
                    GPIO Number for the Right Stick X Axis Positive.

            config BLUCONTROL_RIGHT_STICK_X_MIN
                int "Right Stick X Axis Negative"
                default 37
                range 0 50
                depends on BLUCONTROL_RIGHT_STICK_BUTTONS
                help
