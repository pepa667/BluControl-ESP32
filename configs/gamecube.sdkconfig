#
# BluControl Switch Configuration
#
CONFIG_BLUCONTROL_CONTROL_TYPE_PRO=y
# CONFIG_BLUCONTROL_CONTROL_TYPE_N64 is not set
# CONFIG_BLUCONTROL_CONTROL_TYPE_JOY_L is not set
# CONFIG_BLUCONTROL_CONTROL_TYPE_JOY_R is not set
# CONFIG_BLUCONTROL_CONTROL_TYPE_SNES is not set
# CONFIG_BLUCONTROL_CONTROL_TYPE_NES is not set
# CONFIG_BLUCONTROL_CONTROL_TYPE_FC is not set
# CONFIG_BLUCONTROL_CONTROL_TYPE_GENESIS is not set

#
# Triggers
#
CONFIG_BLUCONTROL_LEFT_TRIGGER_BTN_L=y
# CONFIG_BLUCONTROL_LEFT_TRIGGER_BTN_ZL is not set
CONFIG_BLUCONTROL_RIGHT_TRIGGER_BTN_R=y
# CONFIG_BLUCONTROL_RIGHT_TRIGGER_BTN_ZR is not set
# end of Triggers
# end of BluControl Switch Configuration

#
# BluControl Generic Configuration
#
CONFIG_BLUCONTROL_BUTTONS_LENGTH=0

#
# Buttons
#
CONFIG_BLUCONTROL_BUTTON_A_BTN=1
CONFIG_BLUCONTROL_BUTTON_B_BTN=4
CONFIG_BLUCONTROL_BUTTON_Y_BTN=5
CONFIG_BLUCONTROL_BUTTON_X_BTN=2
CONFIG_BLUCONTROL_BUTTON_L_BTN=14
CONFIG_BLUCONTROL_BUTTON_ZL_BTN=7
CONFIG_BLUCONTROL_BUTTON_R_BTN=15
CONFIG_BLUCONTROL_BUTTON_ZR_BTN=8
CONFIG_BLUCONTROL_BUTTON_START_BTN=12
CONFIG_BLUCONTROL_BUTTON_SELECT_BTN=11
CONFIG_BLUCONTROL_BUTTON_HOME_BTN=13
CONFIG_BLUCONTROL_BUTTON_CAPTURE_BTN=0
CONFIG_BLUCONTROL_BUTTON_STICK_L_BTN=0
CONFIG_BLUCONTROL_BUTTON_STICK_R_BTN=0
# end of Buttons

#
# Triggers
#
CONFIG_BLUCONTROL_LEFT_TRIGGER_BTN=9
CONFIG_BLUCONTROL_RIGHT_TRIGGER_BTN=10
# end of Triggers
# end of BluControl Generic Configuration

#
# BluControl Configuration
#
CONFIG_BLUCONTROL_BUTTONS_PRESS_STATE_LOW=y
# CONFIG_BLUCONTROL_BUTTONS_PRESS_STATE_HIGH is not set

#
# Buttons
#
CONFIG_BLUCONTROL_BUTTON_A_GPIO=22
CONFIG_BLUCONTROL_BUTTON_B_GPIO=23
CONFIG_BLUCONTROL_BUTTON_Y_GPIO=27
CONFIG_BLUCONTROL_BUTTON_X_GPIO=21
CONFIG_BLUCONTROL_DPAD_RIGHT_GPIO=14
CONFIG_BLUCONTROL_DPAD_DOWN_GPIO=12
CONFIG_BLUCONTROL_DPAD_LEFT_GPIO=13
CONFIG_BLUCONTROL_DPAD_UP_GPIO=0
CONFIG_BLUCONTROL_BUTTON_L_GPIO=15
CONFIG_BLUCONTROL_BUTTON_ZL_GPIO=-1
CONFIG_BLUCONTROL_BUTTON_R_GPIO=19
CONFIG_BLUCONTROL_BUTTON_ZR_GPIO=18
CONFIG_BLUCONTROL_BUTTON_START_GPIO=16
CONFIG_BLUCONTROL_BUTTON_SELECT_GPIO=5
CONFIG_BLUCONTROL_BUTTON_HOME_GPIO=17
CONFIG_BLUCONTROL_BUTTON_CAPTURE_GPIO=-1
CONFIG_BLUCONTROL_BUTTON_STICK_L_GPIO=-1
CONFIG_BLUCONTROL_BUTTON_STICK_R_GPIO=-1
# end of Buttons

#
# Triggers
#
# CONFIG_BLUCONTROL_LEFT_TRIGGER_NONE is not set
CONFIG_BLUCONTROL_LEFT_TRIGGER_ANALOG=y
CONFIG_BLUCONTROL_LEFT_TRIGGER_GPIO=25
# CONFIG_BLUCONTROL_LEFT_TRIGGER_IS_INVERTED is not set
CONFIG_BLUCONTROL_LEFT_TRIGGER_ACT=0
# CONFIG_BLUCONTROL_RIGHT_TRIGGER_NONE is not set
CONFIG_BLUCONTROL_RIGHT_TRIGGER_ANALOG=y
CONFIG_BLUCONTROL_RIGHT_TRIGGER_GPIO=26
# CONFIG_BLUCONTROL_RIGHT_TRIGGER_IS_INVERTED is not set
CONFIG_BLUCONTROL_RIGHT_TRIGGER_ACT=0
# end of Triggers

#
# Sticks
#

#
# Left Stick
#
# CONFIG_BLUCONTROL_LEFT_STICK_NONE is not set
CONFIG_BLUCONTROL_LEFT_STICK_ANALOG=y
# CONFIG_BLUCONTROL_LEFT_STICK_N64 is not set
# CONFIG_BLUCONTROL_LEFT_STICK_BUTTONS is not set
CONFIG_BLUCONTROL_LEFT_STICK_X=32
CONFIG_BLUCONTROL_LEFT_STICK_Y=33
CONFIG_BLUCONTROL_LEFT_STICK_X_NORMAL=y
# CONFIG_BLUCONTROL_LEFT_STICK_X_INVERTED is not set
CONFIG_BLUCONTROL_LEFT_STICK_Y_NORMAL=y
# CONFIG_BLUCONTROL_LEFT_STICK_Y_INVERTED is not set
# end of Left Stick

#
# Right stick
#
# CONFIG_BLUCONTROL_RIGHT_STICK_NONE is not set
CONFIG_BLUCONTROL_RIGHT_STICK_ANALOG=y
# CONFIG_BLUCONTROL_RIGHT_STICK_N64 is not set
# CONFIG_BLUCONTROL_RIGHT_STICK_BUTTONS is not set
CONFIG_BLUCONTROL_RIGHT_STICK_X=34
CONFIG_BLUCONTROL_RIGHT_STICK_Y=35
CONFIG_BLUCONTROL_RIGHT_STICK_X_NORMAL=y
# CONFIG_BLUCONTROL_RIGHT_STICK_X_INVERTED is not set
CONFIG_BLUCONTROL_RIGHT_STICK_Y_NORMAL=y
# CONFIG_BLUCONTROL_RIGHT_STICK_Y_INVERTED is not set
# end of Right stick
# end of Sticks

#
# Energy control
#
CONFIG_BLUCONTROL_ENERGY_MODE_SWITCH=y
# CONFIG_BLUCONTROL_ENERGY_MODE_SOFTWARE is not set
# CONFIG_BLUCONTROL_LEDS_MODE_HIGH is not set
CONFIG_BLUCONTROL_LEDS_MODE_LOW=y
# end of Energy control

#
# BluControl SDK Configuration
#
CONFIG_BLUCONTROL_MODE_LENGTH=2
CONFIG_BLUCONTROL_MODE1_LED_GPIO=4
CONFIG_BLUCONTROL_MODE2_LED_GPIO=-1
CONFIG_BLUCONTROL_SECONDS_FOR_SWITCH_MODE=5
CONFIG_BLUCONTROL_SWITCH_BUTTONS_LENGTH=3
CONFIG_BLUCONTROL_SWITCH_BUTTON1_GPIO=15
CONFIG_BLUCONTROL_SWITCH_BUTTON2_GPIO=19
CONFIG_BLUCONTROL_SWITCH_BUTTON3_GPIO=16
# end of BluControl SDK Configuration

#
# BluControl OTA Configuration
#
CONFIG_BLUCONTROL_OTA_LED_GPIO=4
# end of BluControl OTA Configuration
# end of Component config